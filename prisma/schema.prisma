// Resale Dashboard — Prisma Schema (SQLite for local dev)
// Ported from Diggaj Realty (Resale-platform) so business logic/data semantics match 1:1.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums replaced with String for SQLite (matches source project's convention)
// ─────────────────────────────────────────────
// Role: SELLER | BUYER | AGENT | BACKEND | ADMIN
// KycStatus: PENDING | APPROVED | REJECTED
// PropertyStatus: DRAFT | PENDING_VERIFICATION | LIVE | CLOSED | REJECTED
// SellerPlan: BASIC | VERIFIED | VERIFIED_PLUS | ELITE
// OfferStatus: PENDING | ACCEPTED | REJECTED | COUNTERED
// DealStatus: IN_PROGRESS | CLOSED
// PropertyType: RESIDENTIAL | PLOT | COMMERCIAL

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  phone              String?
  passwordHash       String
  role               String // Role enum
  isActive           Boolean  @default(true)
  avatarUrl          String?
  emailNotifications Boolean  @default(true)
  pushNotifications  Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  sellerKyc          SellerKyc?
  propertiesAsSeller Property[]     @relation("SellerProperties")
  propertiesAsAgent  Property[]     @relation("AgentProperties")
  offersAsBuyer      Offer[]        @relation("BuyerOffers")
  dealsAsBuyer       Deal[]         @relation("BuyerDeals")
  dealsAsSeller      Deal[]         @relation("SellerDeals")
  dealsAsAgent       Deal[]         @relation("AgentDeals")
  notifications      Notification[]
  shortlists         Shortlist[]
  savedSearches      SavedSearch[]
  propertyViews      PropertyView[]
  visitsAsBuyer      SiteVisit[]    @relation("BuyerVisits")
  visitsAsAgent      SiteVisit[]    @relation("AgentVisits")

  @@map("users")
}

model SellerKyc {
  id        String   @id @default(cuid())
  userId    String   @unique
  idType    String // IdType enum
  idDocUrl  String?
  selfieUrl String?
  status    String   @default("PENDING") // KycStatus enum
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seller_kyc")
}

model Property {
  id          String    @id @default(cuid())
  sellerId    String
  agentId     String?
  type        String // PropertyType enum
  title       String
  description String?
  location    String
  latitude    Float?
  longitude   Float?
  areaSqft    Float
  bhk         Int?
  askingPrice Float
  unitsAvailable Int    @default(1) // stock: how many identical units of this property are available
  status      String    @default("DRAFT") // PropertyStatus enum
  plan        String    @default("BASIC") // SellerPlan enum
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // ── Structured location (for search/filtering) ──
  city     String?
  locality String?
  pincode  String?

  // ── Area breakdown (RERA mandates carpet area) ──
  carpetAreaSqft       Float?
  builtUpAreaSqft      Float?
  superBuiltUpAreaSqft Float?

  // ── Configuration ──
  bathrooms       Int?
  balconies       Int?
  furnishing      String? // UNFURNISHED | SEMI_FURNISHED | FULLY_FURNISHED
  facing          String? // N | S | E | W | NE | NW | SE | SW
  floorNumber     Int?
  totalFloors     Int?
  ageYears        Int? // age of property in years
  parkingCovered  Int?    @default(0)
  parkingOpen     Int?    @default(0)

  // ── Legal / commercial ──
  possessionStatus   String? // READY_TO_MOVE | UNDER_CONSTRUCTION
  possessionDate     DateTime?
  ownershipType      String? // FREEHOLD | LEASEHOLD | POWER_OF_ATTORNEY | CO_OPERATIVE
  reraId             String?
  priceNegotiable    Boolean   @default(false)
  maintenanceMonthly Float?

  // ── Media & amenities ──
  floorPlanUrl String?
  videoUrl     String?
  amenities    String[]  @default([])

  // ── Builder / project (Bangalore master list) ──
  builderName String?
  projectName String?

  // ── Engagement analytics ──
  viewCount Int @default(0)

  seller User  @relation("SellerProperties", fields: [sellerId], references: [id])
  agent  User? @relation("AgentProperties", fields: [agentId], references: [id])

  photos      PropertyPhoto[]
  offers      Offer[]
  deal        Deal?
  shortlists  Shortlist[]
  views       PropertyView[]
  siteVisits  SiteVisit[]

  @@index([city])
  @@index([status])
  @@map("properties")
}

model PropertyPhoto {
  id         String @id @default(cuid())
  propertyId String
  photoUrl   String
  mediaType  String @default("IMAGE") // IMAGE | VIDEO
  order      Int    @default(0)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_photos")
}

model Offer {
  id            String   @id @default(cuid())
  propertyId    String
  buyerId       String
  amount        Float
  message       String?
  status        String   @default("PENDING_REVIEW") // OfferStatus enum: PENDING_REVIEW | PENDING | ACCEPTED | REJECTED | COUNTERED
  counterAmount Float?
  counterBy     String? // 'BACKEND' | 'SELLER' — who issued the current counterAmount
  reviewedBy    String? // backend user id who forwarded/countered/rejected this negotiation
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer    User        @relation("BuyerOffers", fields: [buyerId], references: [id])
  events   OfferEvent[]

  @@map("offers")
}

model OfferEvent {
  id        String   @id @default(cuid())
  offerId   String
  type      String // CREATED | FORWARDED | COUNTERED_BACKEND | COUNTERED_SELLER | ACCEPTED | REJECTED | COUNTER_ACCEPTED | COUNTER_REJECTED
  amount    Float?
  actorId   String?
  actorRole String?
  note      String?
  createdAt DateTime @default(now())

  offer Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@map("offer_events")
}

model Deal {
  id               String    @id @default(cuid())
  propertyId       String    @unique
  buyerId          String
  sellerId         String
  agentId          String?
  agreedPrice      Float
  tokenAmount      Float?
  tokenDate        DateTime?
  finalAmount      Float?
  finalPaymentDate DateTime?
  paymentMode      String? // BANK_TRANSFER | CHEQUE | OTHER
  transactionRef   String?
  notes            String?
  commissionAmount Float?
  status           String    @default("IN_PROGRESS") // DealStatus enum
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id])
  buyer    User     @relation("BuyerDeals", fields: [buyerId], references: [id])
  seller   User     @relation("SellerDeals", fields: [sellerId], references: [id])
  agent    User?    @relation("AgentDeals", fields: [agentId], references: [id])

  @@map("deals")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AppConfig {
  id                      String   @id @default("singleton")
  commissionPercent       Float    @default(2)
  kycAutoApproveEnabled   Boolean  @default(false)
  listingApprovalRequired Boolean  @default(true)
  supportEmail            String?
  updatedAt               DateTime @updatedAt

  // ── Listing / plan config ──
  maxPhotosPerListing Int   @default(15)
  verifiedPlanPrice   Float @default(0)
  elitePlanPrice      Float @default(0)

  // ── Feature toggles ──
  siteVisitsEnabled   Boolean @default(true)
  savedSearchAlerts   Boolean @default(true)

  @@map("app_config")
}

// ── Buyer engagement ──

model Shortlist {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@map("shortlists")
}

model SavedSearch {
  id            String   @id @default(cuid())
  userId        String
  name          String?
  filters       Json // { q?, type?, city?, minPrice?, maxPrice?, minBhk?, ... }
  alertsEnabled Boolean  @default(true)
  lastAlertedAt DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_searches")
}

model PropertyView {
  id         String   @id @default(cuid())
  userId     String?
  propertyId String
  createdAt  DateTime @default(now())

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([propertyId])
  @@map("property_views")
}

// ── Site visits / agent CRM ──

model SiteVisit {
  id            String    @id @default(cuid())
  propertyId    String
  buyerId       String
  agentId       String?
  status        String    @default("REQUESTED") // REQUESTED | SCHEDULED | COMPLETED | CANCELLED
  requestedDate DateTime
  scheduledDate DateTime?
  buyerNote     String?
  feedback      String? // post-visit notes by agent
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer    User     @relation("BuyerVisits", fields: [buyerId], references: [id], onDelete: Cascade)
  agent    User?    @relation("AgentVisits", fields: [agentId], references: [id])

  @@index([buyerId])
  @@index([agentId])
  @@index([status])
  @@map("site_visits")
}

// ── Admin masters ──

model Amenity {
  id       String  @id @default(cuid())
  name     String  @unique
  category String? // e.g. "Building", "Security", "Recreation"
  active   Boolean @default(true)

  @@map("amenities")
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String?
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("audit_logs")
}
