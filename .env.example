# ── Database (Supabase Postgres) ──────────────────────────────────────────
# Pooled connection (pgbouncer, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by `prisma migrate` / `prisma db push`.
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Auth ──────────────────────────────────────────────────────────────────
# Random 32+ char secret. Generate with: openssl rand -base64 32
# Signs both NextAuth session cookies AND the /api/v1 bearer JWTs.
NEXTAUTH_SECRET="change-me"
# Canonical URL of THIS deployment (the dashboard/API host).
# Local: http://localhost:3000 · Prod: https://<your-app>.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ── Supabase Storage (file uploads) ───────────────────────────────────────
SUPABASE_URL="https://<project-ref>.supabase.co"
# Service-role key (server-only, never exposed to the browser) — lets the API
# upload to the property-media / kyc-documents / deal-documents buckets.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# Public client config (safe to expose).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
